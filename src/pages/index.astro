---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import Hr from "@/components/Hr.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import passport from "@/assets/images/Passport.jpg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");
const notes = await getCollection("notes");

const sortedPosts = getSortedPosts(posts);
const sortedNotes = getSortedPosts(notes);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index">
    <section id="hero" class="pt-8 pb-12">
      <div
        class="flex flex-col gap-6 sm:flex-row sm:items-start sm:justify-between sm:gap-8"
      >
        <div class="flex-1">
          <h1 class="mb-4 text-4xl font-bold sm:text-5xl">Pankaj</h1>
          <p class="mb-4 text-lg leading-relaxed">
            <span class="text-accent italic"
              >He likes cooking, coding, and bullet points.</span
            >
          </p>
          <ul class="mb-4 list-disc space-y-2 pl-5 leading-relaxed">
            <li>
              Completed undergrad in Computer Science at <a
                href="https://www.iitk.ac.in/"
                target="_blank"
                rel="noopener noreferrer"
                class="text-accent hover:underline">IIT Kanpur</a
              >
            </li>
            <li>
              Joining <a
                href="https://www.inmobi.com/"
                target="_blank"
                rel="noopener noreferrer"
                class="text-accent hover:underline">InMobi</a
              > as SDE I
            </li>
            <li>Interested in building and perfecting reliable systems</li>
            <li>Currently in a high-speed learning phase</li>
          </ul>
          {
            // only display if at least one social link is enabled
            SOCIALS.length > 0 && (
              <div class="mt-6 flex flex-wrap items-center gap-4">
                <Socials />
              </div>
            )
          }
        </div>
        <div class="flex-shrink-0">
          <Image
            src={passport}
            alt="Passport"
            class="h-auto w-36 rounded-lg sm:w-40 md:w-44"
          />
        </div>
      </div>
    </section>

    <Hr />

    <div
      class:list={[
        "mx-auto grid max-w-app grid-cols-1 gap-6 px-4",
        { "md:grid-cols-2": sortedPosts.length > 0 && sortedNotes.length > 0 },
      ]}
    >
      {
        sortedPosts.length > 0 && (
          <div id="recent-posts" class="pt-12 pb-6">
            <div class="mb-4 flex items-center justify-between gap-4">
              <h2 class="text-xl font-semibold">Recent blog posts</h2>
              <LinkButton href="/posts/" class="shrink-0 whitespace-nowrap">
                All Posts
                <IconArrowRight class="inline-block rtl:-rotate-180" />
              </LinkButton>
            </div>
            <ul>
              {sortedPosts.map(
                (data, index) =>
                  index < SITE.postPerIndex && <Card variant="h4" {...data} />
              )}
            </ul>
          </div>
        )
      }
      {
        sortedNotes.length > 0 && (
          <div id="recent-notes" class="pt-12 pb-6">
            <div class="mb-4 flex items-center justify-between gap-4">
              <h2 class="text-xl font-semibold">Recent notes</h2>
              <LinkButton href="/notes/" class="shrink-0 whitespace-nowrap">
                All Notes
                <IconArrowRight class="inline-block rtl:-rotate-180" />
              </LinkButton>
            </div>
            <ul>
              {sortedNotes.map(
                (data, index) =>
                  index < SITE.postPerIndex && <Card variant="h4" {...data} />
              )}
            </ul>
          </div>
        )
      }
    </div>
  </main>
  <!-- <Footer /> -->
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
